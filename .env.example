# Sensei configuration

# Kibana base URL (no trailing slash)
KIBANA_URL=https://your-deployment.kb.us-central1.gcp.elastic.cloud

# Elasticsearch base URL (no trailing slash; usually port :443 on Cloud)
ELASTICSEARCH_URL=https://your-deployment.es.us-central1.gcp.elastic.cloud:443

# Encoded API key (Kibana → Stack Management → API Keys → Create)
# Same key works for both Kibana and Elasticsearch on Serverless
ELASTICSEARCH_API_KEY=replace_me
KIBANA_API_KEY=${ELASTICSEARCH_API_KEY}
